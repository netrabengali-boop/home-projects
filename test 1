import random
secret_number=random.randint(1,50)
max_guesses=5
print ("let's play a game! I'm thinking of a number between 1 and 50. You have 5 guesses to find it.")
for guesses_taken in range(1, max_guesses + 1):
    print ("Take a guess.")
    guess=(input())
    guess=int(guess)
    if guess < secret_number:
        print ("Your guess is too low.")
    elif guess > secret_number:
        print ("Your guess is too high.")
    else:
        break   
if guess == secret_number:
    print ("Good job! You guessed my number in " + str(guesses_taken) + " guesses!")
else:    print ("Nope. The number I was thinking of was " + str(secret_number))
